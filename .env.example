PORT=8080
LOKI_URL=http://loki-stack.monitoring.svc.cluster.local:3100
OLLAMA_URL=http://host.docker.internal:11434
OLLAMA_MODEL=llama3.2:latest
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_APP_TOKEN=xapp-your-app-level-token
SLACK_CHANNEL=#neurokube-alerts
# Host-only: path to kubeconfig when running the brain binary on your machine.
# Do NOT put this in the cluster Secret — `make brain-deploy` strips KUBECONFIG so the pod uses in-cluster credentials.
# KUBECONFIG=C:/Users/YOU/.kube/config
